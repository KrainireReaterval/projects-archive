---
/**
 * [section]/[slug].astro — individual project case study.
 * Renders the MDX body, emits CreativeWork JSON-LD, and includes Giscus.
 * Statically generated for every entry via getStaticPaths.
 */
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import GiscusComments from '../../components/GiscusComments.astro';
import WIPBadge from '../../components/WIPBadge.astro';
import { withBase } from '../../lib/paths';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((entry) => ({
    params: { section: entry.data.section, slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);

const sectionNames: Record<string, string> = {
  uiux: 'UI/UX Redesigns',
  products: 'Products',
  cv: 'Computer Vision',
  gis: 'GIS + Spatial',
};

// JSON-LD: CreativeWork.
const schema = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: data.title,
  about: data.thesis,
  dateCreated: String(data.year),
  creator: { '@type': 'Person', name: 'krval' },
  keywords: data.tags.join(', '),
  url: new URL(`/${data.section}/${entry.id}`, Astro.site).href,
};
---

<Layout
  title={`${data.title} — krval`}
  description={data.thesis}
  ogImage={data.ogImage}
  schema={schema}
>
  <article class="case grid">
    <header class="case-head">
      <nav class="crumbs label" aria-label="Breadcrumb">
        <a href={withBase('/')}>Home</a>
        <span aria-hidden="true">/</span>
        <a href={withBase(`/${data.section}`)}>{sectionNames[data.section]}</a>
      </nav>

      <h1 class="case-title">
        {data.title}
        {data.wip && <span class="case-wip"><WIPBadge /></span>}
      </h1>

      <p class="label case-sub">{data.year} · {data.role}</p>
      <ul class="tags">
        {data.tags.map((t) => <li class="pill">{t}</li>)}
      </ul>

      <p class="case-thesis">{data.thesis}</p>
    </header>

    <div class="case-summary">
      <dl>
        <dt class="label">Problem</dt>
        <dd>{data.problem}</dd>
        <dt class="label">Outcome</dt>
        <dd>{data.outcome}</dd>
      </dl>
    </div>

    <div class="case-prose">
      <Content />
    </div>
  </article>

  <div class="grid">
    <GiscusComments />
  </div>
</Layout>

<style>
  .case {
    padding-block: clamp(2rem, 6vw, 4rem);
    row-gap: clamp(1.5rem, 4vw, 2.5rem);
  }
  .case-head {
    grid-column: 1 / span 8;
  }
  .crumbs {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }
  .crumbs a:hover {
    color: var(--color-text);
  }
  .case-title {
    font-size: var(--fs-hero);
    margin-bottom: 0.75rem;
  }
  .case-wip {
    display: inline-block;
    vertical-align: middle;
    margin-left: 0.5rem;
  }
  .case-sub {
    margin-bottom: 0.75rem;
  }
  .tags {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .case-thesis {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    line-height: 1.4;
    max-width: 40ch;
  }

  .case-summary {
    grid-column: 9 / 13;
  }
  .case-summary dl {
    margin: 0;
    position: sticky;
    top: 2rem;
    display: grid;
    gap: 0.25rem;
    border-left: 2px solid var(--color-line);
    padding-left: 1rem;
  }
  .case-summary dt {
    margin-top: 0.75rem;
  }
  .case-summary dd {
    margin: 0;
  }

  .case-prose {
    grid-column: 1 / span 8;
    max-width: 68ch;
  }
  .case-prose :global(h2) {
    font-size: var(--fs-section);
    margin-block: 2rem 0.75rem;
  }
  .case-prose :global(h3) {
    margin-block: 1.5rem 0.5rem;
  }
  .case-prose :global(p) {
    margin-bottom: 1rem;
  }
  .case-prose :global(ul),
  .case-prose :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.25rem;
  }
  .case-prose :global(img) {
    border-radius: 8px;
    margin-block: 1.5rem;
  }

  @media (max-width: 900px) {
    .case-head,
    .case-summary,
    .case-prose {
      grid-column: 1 / -1;
    }
    .case-summary dl {
      position: static;
    }
  }
</style>
