---
/**
 * SectionView.astro — shared rendering for the four section index pages.
 * Queries the projects collection, filters by section, sorts by year desc,
 * and renders WIP cards LAST. Emits BreadcrumbList JSON-LD and Giscus.
 *
 * Pages pass `section`, a human `title`, and a `description`. The GIS page
 * additionally injects its own 3D slot via the default <slot /> (rendered
 * above the project list).
 */
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ProjectCard from './ProjectCard.astro';
import GiscusComments from './GiscusComments.astro';
import { withBase } from '../lib/paths';

interface Props {
  section: 'uiux' | 'products' | 'cv' | 'gis';
  title: string;
  description: string;
}

const { section, title, description } = Astro.props;

const all = await getCollection('projects', (e) => e.data.section === section);
const projects = all.sort((a, b) => {
  // WIP last, then year descending.
  if (a.data.wip !== b.data.wip) return a.data.wip ? 1 : -1;
  return b.data.year - a.data.year;
});

// JSON-LD: BreadcrumbList (Home › Section).
const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: new URL('/', Astro.site).href,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: title,
      item: new URL(`/${section}`, Astro.site).href,
    },
  ],
};
---

<Layout title={`${title} — krval`} description={description} schema={schema}>
  <!-- Forward page-specific <head> content (e.g. the model-viewer script). -->
  <Fragment slot="head"><slot name="head" /></Fragment>

  <section class="section-head grid">
    <div class="section-head-inner">
      <h1 class="section-title">{title}</h1>
      <p class="section-desc">{description}</p>
    </div>
  </section>

  <!-- Optional extra content (e.g. GIS 3D slot) renders here. -->
  <slot />

  <section class="project-list grid">
    {
      projects.length === 0 ? (
        <p class="empty label">No published projects yet — check back soon.</p>
      ) : (
        projects.map((p) => (
          <ProjectCard
            href={withBase(`/${p.data.section}/${p.id}`)}
            title={p.data.title}
            year={p.data.year}
            role={p.data.role}
            tags={p.data.tags}
            image={p.data.image}
            thesis={p.data.thesis}
            problem={p.data.problem}
            outcome={p.data.outcome}
            wip={p.data.wip}
          />
        ))
      )
    }
  </section>

  <div class="grid">
    <GiscusComments />
  </div>
</Layout>

<style>
  .section-head {
    padding-block: clamp(2rem, 6vw, 4rem) clamp(1rem, 3vw, 2rem);
  }
  .section-head-inner {
    grid-column: 1 / span 9;
  }
  .section-title {
    font-size: var(--fs-section);
    margin-bottom: 0.75rem;
  }
  .section-desc {
    color: var(--color-muted);
    max-width: 55ch;
  }
  .project-list {
    gap: clamp(1rem, 3vw, 2rem);
    row-gap: clamp(1.5rem, 4vw, 2.5rem);
  }
  .empty {
    grid-column: 1 / -1;
  }
</style>
